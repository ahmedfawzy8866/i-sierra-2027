{
  "name": "sierra-estates-platform",
  "version": "1.0.0",
  "description": "Sierra Estates 2027 - Master Monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:realty": "pnpm --filter sierra-estates-realty dev",
    "dev:admin": "pnpm --filter sierra-estates-admin-portal dev",
    "build:realty": "pnpm --filter sierra-estates-realty build",
    "build:admin": "pnpm --filter sierra-estates-admin-portal build",
    "dev": "pnpm --filter sierra-estates-realty dev",
    "build": "pnpm --filter sierra-estates-realty build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:ci": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.9.16",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}