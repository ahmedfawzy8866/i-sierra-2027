{
  "name": "sierra-blu-platform",
  "version": "1.0.0",
  "description": "Sierra Blu - Luxury Real Estate Platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter sierra-blu-platform dev",
    "dev:functions": "pnpm --filter sierra-blu-functions dev",
    "build": "pnpm --filter sierra-blu-platform build",
    "build:functions": "pnpm --filter sierra-blu-functions build",
    "start": "pnpm --filter sierra-blu-platform start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "deploy:firebase": "firebase deploy --only firestore:rules,storage,functions",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy:functions": "firebase deploy --only functions",
    "validate": "pnpm lint && pnpm type-check && pnpm test:ci && pnpm build"
  },
  "devDependencies": {
    "turbo": "^2.9.16",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "uuid": ">=11.1.1"
    }
  }
}
