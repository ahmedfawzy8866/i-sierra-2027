NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Google AI (Gemini)
GOOGLE_AI_API_KEY=your_gemini_api_key

# Firebase Admin SDK (Service Account JSON)
# For production, this should be a JSON string
FIREBASE_SERVICE_ACCOUNT_JSON=

# Arize Phoenix (Observability)
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=sierra-estates-platform

# Integrations
OPENCLAW_BASE_URL=http://127.0.0.1:18789/v1
OPENCLAW_TOKEN=your_openclaw_token
PROPERTY_FINDER_API_GATEWAY=https://gateway.propertyfinder.com/v2
PROPERTY_FINDER_CLIENT_ID=your_property_finder_client_id
PROPERTY_FINDER_CLIENT_SECRET=your_property_finder_client_secret
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Auth & Security
# Shared secret for internal server-to-server API calls (X-SBR-SECRET-KEY header)
SBR_SECRET_KEY=your_internal_shared_secret_key

# Cron job authorization secret (used by /api/cron/* routes)
CRON_SECRET=your_cron_secret_key

# Property Finder webhook HMAC secret (used by /api/webhooks/property-finder)
PF_WEBHOOK_SECRET=your_property_finder_webhook_secret

# Properties sync API key (used by /api/properties/sync)
SYNC_API_KEY=your_sync_api_key

# Public site URL (used for generating concierge/selection links)
NEXT_PUBLIC_SITE_URL=https://sierrablu.luxury

