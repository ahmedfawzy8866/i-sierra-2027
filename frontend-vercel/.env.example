# ───────────────────────────────────────────────────────────
#  Sierra Blu — frontend-vercel environment template
#  Copy to `.env.local` and fill in real values. NEVER commit `.env.local`.
# ───────────────────────────────────────────────────────────

# --- Property Finder Integration API ---
PF_API_KEY=your_property_finder_api_key
PF_API_SECRET=your_property_finder_api_secret

# --- Firebase (client SDK — safe to expose, but still keep out of git) ---
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# --- OpenClaw scraping infrastructure ---
OPENCLAW_BASE_URL=https://your-openclaw-endpoint
OPENCLAW_TOKEN=your_openclaw_token

# --- Telegram (Sierra AI bot) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Google ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_browser_key
GOOGLE_MAPS_API_KEY=your_google_maps_server_key
GOOGLE_AI_API_KEY=your_gemini_api_key

# --- Security / automation ---
CRON_SECRET=generate_a_long_random_string
SBR_SECRET_KEY=generate_a_long_random_string
ZAPIER_CALENDAR_WEBHOOK_URL=https://hooks.zapier.com/your-hook
