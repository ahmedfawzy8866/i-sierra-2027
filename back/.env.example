# Sierra Estates 1.0 — credential vault TEMPLATE (key names only; NEVER commit the real .env)
# Deploy: copy to /etc/sierra-estates/.env on the VPS, fill values, chmod 600, chown sierra.

# Gemini 1.5 Pro — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Path to the Firebase Admin service-account JSON (downloaded from Firebase console).
# This file itself must live OUTSIDE the repo (e.g. /etc/sierra-estates/service-account.json).
FIREBASE_CONFIG=/etc/sierra-estates/service-account.json

# Telegram telemetry (optional but recommended for 24/7 uptime visibility)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Tunables
POLL_INTERVAL_SEC=60
AGENT_STATE_DIR=/opt/sierra-estates/back/.agent
