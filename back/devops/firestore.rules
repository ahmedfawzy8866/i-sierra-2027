rules_version = '2';
// Sierra Estates 1.0 — Firestore Security Rules (Firebase Spark / zero-cost tier)
// Anti-Gravity separation enforced AT THE DATABASE:
//   • Tier-1 client hub (sierra-blu-realty on Vercel)  = READ-ONLY, public listings only.
//   • Tier-2 admin portal (authenticated staff)        = read/write CRM + intake.
//   • engine_core.py uses the Admin SDK service account = BYPASSES these rules by design.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function role()     { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isStaff()  { return signedIn() && role() in ['admin', 'manager', 'agent']; }
    function isAdmin()  { return signedIn() && role() == 'admin'; }

    // Portfolio Assets — Tier-1 streams published listings with zero auth; staff write.
    match /listings/{id} {
      allow read:  if resource.data.status == 'published' || isStaff();
      allow create, update, delete: if isStaff();
    }

    // WhatsApp intake queue — written by the Tier-2 webhook, drained by engine_core (Admin SDK).
    // No client read/write: keep raw inbound data private.
    match /whatsapp_intake/{id} {
      allow read, write: if false;
    }

    // Strategic Pipeline (Investment Stakeholders) — staff only, never public.
    match /leads/{id} { allow read, write: if isStaff(); }
    match /deals/{id} { allow read, write: if isStaff(); }

    // User/role docs — self-read; only admin mutates roles.
    match /users/{uid} {
      allow read:  if signedIn() && (request.auth.uid == uid || isStaff());
      allow write: if isAdmin();
    }

    // Default deny — anything not matched above is locked.
    match /{document=**} { allow read, write: if false; }
  }
}
