# ══════════════════════════════════════════════════════════════
#  sierra estates PLATFORM — ENVIRONMENT VARIABLES
#  Copy this file to .env.local and fill in your values.
#  Never commit .env.local to source control.
# ══════════════════════════════════════════════════════════════


# ── FIREBASE CLIENT (required) ──────────────────────────────
# Found in Firebase Console → Project Settings → Your Apps → Web App config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=


# ── FIREBASE ADMIN SDK (one option required) ─────────────────
# Option A — Recommended for Vercel: paste entire service account JSON as a single line
# Found in Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B — Individual fields (alternative to Option A)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=


# ── AI / GEMINI (required) ───────────────────────────────────
# Found in Google AI Studio → API Keys
GOOGLE_AI_API_KEY=


# ── SECURITY SECRETS (required) ─────────────────────────────
# Generate strong random strings (e.g. openssl rand -hex 32)
CRON_SECRET=
SBR_SECRET_KEY=
PF_WEBHOOK_SECRET=
SYNC_API_KEY=


# ── INTEGRATIONS (required for full functionality) ───────────

# Telegram Notifications (for admin alerts)
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal/group chat ID where alerts are sent
TELEGRAM_CHAT_ID=

# WhatsApp Messaging (Meta Business Platform)
# Get from Meta App Dashboard → WhatsApp Business Account
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# PropertyFinder Integration
PROPERTY_FINDER_CLIENT_ID=
PROPERTY_FINDER_CLIENT_SECRET=

# Google Sheets Sync (for inventory backup)
# Get from Google Cloud Console → Sheets API
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_API_KEY=

# OpenClaw AI gateway — replace with your deployed instance URL
OPENCLAW_BASE_URL=https://your-openclaw-host/v1
OPENCLAW_TOKEN=


# ── BRAND / CONTACT CONFIG (optional, has defaults) ─────────
NEXT_PUBLIC_SITE_URL=https://sierrablu.luxury
NEXT_PUBLIC_SUPPORT_PHONE=+20 10 61399688
NEXT_PUBLIC_SUPPORT_EMAIL=support@sierrablu.luxury
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/201061399688
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/Sierrablurealtybot


# ── THIRD-PARTY INTEGRATIONS ────────────────────────────────
PROPERTY_FINDER_API_GATEWAY=https://gateway.propertyfinder.com/v2


# ── PAYMENT & TRANSACTIONS (optional) ──────────────────────
# Stripe payment processing
# Get from Stripe Dashboard → API Keys
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# For webhook signature verification in /api/webhooks/stripe
# Get from Stripe Dashboard → Webhooks


# ── EMAIL SERVICE (optional but recommended) ───────────────
# Choose one: SendGrid OR Resend

# SendGrid Configuration
# Get from SendGrid Dashboard → API Keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@sierrablu.luxury

# OR Resend Configuration
# Get from Resend Dashboard → API Keys
RESEND_API_KEY=


# ── OBSERVABILITY (optional) ─────────────────────────────────
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=sierra-estates-platform


# ── LOCAL DEV ONLY ───────────────────────────────────────────
# WARNING: Never set SKIP_APP_CHECK=true in production
# SKIP_APP_CHECK=true
